<idea-plugin>
    <id>dev.bartoszmaka.splitjoin</id>
    <name>SplitJoin</name>
    <vendor email="bartoszmaka95@gmail.com">bartoszmaka</vendor>
    <description><![CDATA[
        Splitjoin for JetBrains IDEs. Converts the construct under the caret between
        single-line and multi-line forms. Inspired by vim-splitjoin.

        <h3>Keybindings</h3>

        <p>
            <b>IdeaVim</b> — add to your <code>.ideavimrc</code>:
        </p>
        <pre>
nnoremap &lt;C-m&gt;&lt;C-s&gt; :action Splitjoin.Split&lt;CR&gt;
nnoremap &lt;C-m&gt;&lt;C-d&gt; :action Splitjoin.Join&lt;CR&gt;
        </pre>

        <p>
            <b>Regular keymap</b> — assign shortcuts via
            <i>Settings &gt; Keymap &gt; Plugins &gt; SplitJoin</i>.
        </p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="splitjoin-json.xml">com.intellij.modules.json</depends>
    <depends optional="true" config-file="splitjoin-ruby.xml">com.intellij.modules.ruby</depends>
    <depends optional="true" config-file="splitjoin-js.xml">JavaScript</depends>
    <depends optional="true" config-file="splitjoin-html.xml">com.intellij.modules.xml</depends>

    <extensionPoints>
        <extensionPoint qualifiedName="com.splitjoin.handler"
                        interface="com.splitjoin.core.SplitJoinHandler"
                        dynamic="true"/>
    </extensionPoints>

    <actions>
        <action id="Splitjoin.Split"
                class="com.splitjoin.core.SplitAction"
                text="Splitjoin split"
                description="Convert single-line to multi-line">
            <add-to-group group-id="CodeMenu" anchor="last"/>
        </action>
        <action id="Splitjoin.Join"
                class="com.splitjoin.core.JoinAction"
                text="Splitjoin join"
                description="Convert multi-line to single-line">
            <add-to-group group-id="CodeMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
